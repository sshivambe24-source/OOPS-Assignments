#include<iostream>
using namespace std;
class Polygon {
protected:
    int width, height;
public:
    void set_value(int w, int h) {
        width = w;
        height = h;
    }
    virtual float calculate_area() {
        return 0;
    }
};
class Rectangle : public Polygon {
public:
    float calculate_area() {
        return width * height;
    }
};
class Triangle : public Polygon {
public:
    float calculate_area() {
        return 0.5 * width * height;
    }
};
int main() {
    Polygon *p;  
    Rectangle r;
    Triangle t;
    p = &r;
    p->set_value(10, 5);
    cout << "Area of Rectangle: " << p->calculate_area() << endl;
    p = &t;
    p->set_value(10, 5);
    cout << "Area of Triangle: " << p->calculate_area() << endl;
    return 0;
}
